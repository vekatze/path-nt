import {
  core.list {filter, for-each},
  core.string {intercalate, split},
  noa.gen {Gen, gen},
  noa.gen.custom.string {Config, string-gen},
  noa.gen.list {list-gen},
  this.path {separator},
}

constant path-components: gen(list(string)) {
  list-gen(
    string-gen(
      Config{
        min-length := 0,
        max-length := none,
        rune-generator := none,
        rune-acceptor := {
          (r) => {
            and(ne-rune(r, `/`), ne-rune(r, `\0`))
          }
        },
      },
    ),
  )
}

constant paths: gen(string) {
  let Gen{generate, shrink} = path-components;
  Gen{
    generate := {
      (size) => {
        let xs = generate(size);
        intercalate(xs, *separator)
      }
    },
    shrink := {
      (path) => {
        pin path = path;
        let components = split(path, separator);
        let components-list = shrink(components);
        let cands =
          for-each(components-list, (components) => {
            intercalate(components, *separator)
          });
        filter(cands, (cand) => {
          ne-string(path, cand)
        })
      }
    },
  }
}
